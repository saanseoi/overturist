# Type : divisionId
# Required: No
# Default : None
# Note : Set this to skip division resolution if you already know your division's Id
# DIVISION_ID="b4f09a9f-4cba-4a7c-bf58-2e63bc2e913d"

# Type: featureType
# Required: No
# Default: All
# Note : Set this to limit downloads to specific feature types
# FEATURE_TYPES="building,address,segment"

# Type: boolean
# Required: No
# Default: true
# Note: Set to false to skip the interactive confirmation step for CLI or env feature selections
# CONFIRM_FEATURE_SELECTION=false

# Type: releaseVersion
# Required: No
# Default : Latest
# Note : Set this to use a specific Overture Maps release version
# RELEASE_VERSION="2026-03-18.0"

# Type: filterMode
# Required: No
# Default : Division
# Note : Set this to use a specific Overture Maps release version
# Options : 'division' | 'bbox' | 'world'
# TARGET="division"

# Type: bbox
# Required: No
# Default : Inferred from Division's geometry
# Note : Only set this if you want a narrower area within a division than the division iteself.
# BBOX_XMIN=113.77
# BBOX_XMAX=114.57
# BBOX_YMIN=22.08
# BBOX_YMAX=22.63

# Type: onFileExists
# Options : skip|replace|abort
# Required: No
# Default : Skip
# Note : Set default behavior when files already exist
# ON_FILE_EXISTS="skip"

# Type: locale
# Options : ISO language codes
# Required: No
# Default : en
# Note : Names are localised to this locale where available
# LOCALE="en"

# Type: spatialFrame
# Required: No
# Default: division
# Options: division|bbox
# Note: Chooses the exact spatial frame used for filtering.
# SPATIAL_FRAME="division"

# Type: spatialPredicate
# Required: No
# Default: intersects
# Options: intersects|within
# Note: Controls whether features that touch the frame are kept or only features fully contained by it.
# SPATIAL_PREDICATE="intersects"

# Type: spatialGeometry
# Required: No
# Default: clip-smart
# Options: preserve|clip-smart|clip-all
# Note: Controls whether matched features keep their original geometry or are clipped to the selected frame.
# SPATIAL_GEOMETRY="clip-smart"
