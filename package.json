{
  "name": "@saanseoi/overturist",
  "version": "0.1.0",
  "description": "CLI to obtain Overture Maps data from S3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saanseoi/overturist.git"
  },
  "bugs": {
    "url": "https://github.com/saanseoi/overturist/issues"
  },
  "homepage": "https://github.com/saanseoi/overturist#readme",
  "main": "overturist.ts",
  "directories": {
    "bin": "bin"
  },
  "files": [
    "bin",
    "overturist.ts",
    "libs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --project .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:branch": "bunx branch-name-lint .husky/branch-name-lint.json",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:migrate": "biome migrate --write",
    "prepare": "husky",
    "publish:dry-run": "npm publish --dry-run --access public"
  },
  "keywords": [
    "overture-maps",
    "geospatial",
    "cli",
    "bun",
    "duckdb"
  ],
  "author": "Mart van de Ven",
  "license": "MIT",
  "packageManager": "bun@1.3.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "os": [
    "linux"
  ],
  "cpu": [
    "x64"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@bomb.sh/args": "^0.3.1",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@duckdb/node-api": "^1.5.1-r.1",
    "@duckdb/node-bindings-linux-x64": "^1.5.1-r.1",
    "cheerio": "^1.2.0",
    "fast-wrap-ansi": "^0.2.0",
    "kleur": "^4.1.5",
    "node-fetch": "^3.3.2",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "husky": "^9.1.7"
  }
}
