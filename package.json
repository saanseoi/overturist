        "@duckdb/node-api": "^1.4.2-r.1",
        "@duckdb/node-bindings-linux-x64": "^1.4.2-r.1",
        "cheerio": "^1.1.2",
        "fast-wrap-ansi": "^0.2.0",
        "kleur": "^4.1.5",
        "node-fetch": "^3.3.2",
        "picocolors": "^1.1.1",
        "string-width": "^8.1.0",
        "typescript": "^5.9.3"
    },
